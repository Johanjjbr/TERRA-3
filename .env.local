# Supabase Configuration
# Obtén estos valores del dashboard de Supabase en:
# https://app.supabase.com → Proyecto → Settings → API

# URL de tu proyecto Supabase (termina en supabase.co)
VITE_SUPABASE_URL=https://tu-proyecto.supabase.co

# Clave pública (anon key) - La encontras en Settings → API
VITE_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Variables opcionales para desarrollo
VITE_APP_ENV=development
VITE_API_TIMEOUT=30000
